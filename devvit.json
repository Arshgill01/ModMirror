{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "modmirror",
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "height": "tall",
        "inline": true
      }
    }
  },
  "menu": {
    "items": [
      {
        "label": "Apply ModMirror Policy",
        "description": "Open ModMirror policy guidance for this comment.",
        "location": "comment",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/apply-policy-comment"
      },
      {
        "label": "Apply ModMirror Policy",
        "description": "Open ModMirror policy guidance for this post.",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/apply-policy-post"
      },
      {
        "label": "Open ModMirror dashboard",
        "description": "Create and open the ModMirror policy dashboard for this subreddit.",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/open-dashboard"
      }
    ]
  },
  "forms": {
    "applyPolicyTarget": "/internal/form/apply-policy-target-submit",
    "dashboardLaunch": "/internal/form/dashboard-launch-submit"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "permissions": {
    "reddit": true
  },
  "dev": {
    "subreddit": "modmirror_dev"
  }
}
